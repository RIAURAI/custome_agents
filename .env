SECRET_KEY=your-very-secret-key-change-this
DEBUG=True

# Database — PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=workhub_db
DB_USER=workhub_user
DB_PASSWORD=workhub_pass123
DB_HOST=localhost
DB_PORT=5432

# Microsoft Azure App Registration
MS_CLIENT_ID=your-azure-app-client-id
MS_CLIENT_SECRET=your-azure-app-client-secret
MS_TENANT_ID=common

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Fernet encryption key (run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" )
FERNET_KEY=your-32-byte-fernet-key-here
